# Kopiér denne fil til .env og udfyld dine egne værdier
# Hent OpenRouter-nøgle på: https://openrouter.ai/keys
ANTHROPIC_API_KEY=sk-or-v1-...

# Hent Notion-nøgle på: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_...

# Find database-ID i Notion-databasens URL
NOTION_DATABASE_ID=...

# SharePoint (ikke i brug endnu)
SHAREPOINT_SITE_URL=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=
